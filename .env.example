# Salin file ini menjadi .env lalu sesuaikan nilainya.

# Rahasia untuk menandatangani sesi login (JWT). Minimal 32 karakter acak.
AUTH_SECRET="ganti-dengan-string-acak-panjang"

# Folder data PGlite (Postgres lokal in-process) untuk dev. Dipakai bila DATABASE_URL kosong.
PGLITE_DIR="./.data/pglite"

# Folder lokal untuk simpan foto profil saat dev (DATABASE_URL kosong).
# Di produksi, foto disimpan ke Vercel Blob lewat BLOB_READ_WRITE_TOKEN.
AVATAR_DIR="./.data/avatars"
# Dibuat otomatis setelah Public Blob Store dihubungkan ke project Vercel.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."


# Produksi: koneksi Postgres/Supabase. Jika diisi, dipakai menggantikan PGlite.
# DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"
